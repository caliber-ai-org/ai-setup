{
  "name": "caliber-demo-video",
  "private": true,
  "scripts": {
    "dev": "remotion studio",
    "build": "remotion render CaliberDemo assets/demo.mp4 --codec h264",
    "build:gif": "remotion render CaliberDemo ../demo-header.gif --codec gif --every-nth-frame 3 --scale 0.66",
    "build:gif:hq": "remotion render CaliberDemo ../demo-header.gif --codec gif --every-nth-frame 2 --scale 1",
    "optimize:gif": "bash scripts/optimize-gif.sh",
    "build:readme-gif": "pnpm run build:gif && pnpm run optimize:gif"
  },
  "dependencies": {
    "@remotion/google-fonts": "^4.0.0",
    "@remotion/cli": "^4.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "^4.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "typescript": "^5.7.0"
  }
}
